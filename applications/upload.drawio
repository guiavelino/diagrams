<mxfile host="app.diagrams.net">
  <diagram name="aws-audio-upload-architecture">
    <mxGraphModel dx="1420" dy="900" grid="1" gridSize="10" guides="1">
      <root>

        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- AWS CLOUD -->
        <mxCell id="aws" value="AWS Cloud" style="rounded=1;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="60" width="1200" height="620" as="geometry"/>
        </mxCell>

        <!-- VPC -->
        <mxCell id="vpc" value="VPC" style="rounded=1;strokeWidth=2;" vertex="1" parent="aws">
          <mxGeometry x="40" y="40" width="1120" height="540" as="geometry"/>
        </mxCell>

        <!-- PUBLIC SUBNET -->
        <mxCell id="publicsubnet" value="Public Subnet" style="rounded=1;dashed=1;" vertex="1" parent="vpc">
          <mxGeometry x="40" y="60" width="1040" height="120" as="geometry"/>
        </mxCell>

        <!-- PRIVATE APP SUBNET -->
        <mxCell id="privatesubnetapp" value="Private Subnet - Application Tier" style="rounded=1;dashed=1;" vertex="1" parent="vpc">
          <mxGeometry x="40" y="220" width="1040" height="140" as="geometry"/>
        </mxCell>

        <!-- PRIVATE WORKER SUBNET -->
        <mxCell id="privatesubnetworker" value="Private Subnet - Worker Tier" style="rounded=1;dashed=1;" vertex="1" parent="vpc">
          <mxGeometry x="40" y="400" width="1040" height="120" as="geometry"/>
        </mxCell>

        <!-- USER -->
        <mxCell id="user" value="User / Browser" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="300" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- ALB -->
        <mxCell id="alb" value="Application Load Balancer" style="rounded=1;" vertex="1" parent="publicsubnet">
          <mxGeometry x="300" y="30" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- ECS API -->
        <mxCell id="ecsapi" value="ECS API Service" style="rounded=1;" vertex="1" parent="privatesubnetapp">
          <mxGeometry x="280" y="40" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- SQS -->
        <mxCell id="sqs" value="SQS Queue" style="rounded=1;" vertex="1" parent="privatesubnetapp">
          <mxGeometry x="560" y="40" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- WORKER -->
        <mxCell id="worker" value="ECS Worker Service" style="rounded=1;" vertex="1" parent="privatesubnetworker">
          <mxGeometry x="520" y="30" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- RDS -->
        <mxCell id="rds" value="RDS Database" style="rounded=1;" vertex="1" parent="privatesubnetworker">
          <mxGeometry x="800" y="30" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- S3 TEMP -->
        <mxCell id="s3temp" value="S3 Temp Bucket" style="rounded=1;" vertex="1" parent="aws">
          <mxGeometry x="1080" y="160" width="200" height="70" as="geometry"/>
        </mxCell>

        <!-- S3 FINAL -->
        <mxCell id="s3final" value="S3 Final Bucket (CD Storage)" style="rounded=1;" vertex="1" parent="aws">
          <mxGeometry x="1080" y="320" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- EDGES -->

        <mxCell id="e1" edge="1" parent="1" source="user" target="alb">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" edge="1" parent="1" source="alb" target="ecsapi">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" value="generate presigned url" edge="1" parent="1" source="ecsapi" target="s3temp">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" value="direct upload" edge="1" parent="1" source="user" target="s3temp">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" value="confirm upload" edge="1" parent="1" source="ecsapi" target="sqs">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" value="consume message" edge="1" parent="1" source="sqs" target="worker">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" value="move file to final storage" edge="1" parent="1" source="worker" target="s3final">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e8" value="update metadata" edge="1" parent="1" source="worker" target="rds">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>