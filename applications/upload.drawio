<mxfile host="app.diagrams.net">
  <diagram name="aws-audio-upload-architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="user" value="User" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="260" width="120" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="frontend" value="Frontend App" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="260" width="160" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="alb" value="Application Load Balancer" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="260" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="ecsapi" value="ECS API Service" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="260" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="s3temp" value="S3 Temp Bucket uploads temp" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="120" width="200" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="sqs" value="SQS Queue audio processing" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="260" width="200" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="worker" value="ECS Worker Service" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="260" width="200" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="s3final" value="S3 Final Bucket cds cdId file.mp3" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="120" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="rds" value="RDS Database metadata" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="400" width="200" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="e1" edge="1" parent="1" source="user" target="frontend">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" edge="1" parent="1" source="frontend" target="alb">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" edge="1" parent="1" source="alb" target="ecsapi">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" value="generate presigned url" edge="1" parent="1" source="ecsapi" target="s3temp">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" value="direct upload" edge="1" parent="1" source="frontend" target="s3temp">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" value="confirm upload" edge="1" parent="1" source="ecsapi" target="sqs">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" value="consume job" edge="1" parent="1" source="sqs" target="worker">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e8" value="move audio to final storage" edge="1" parent="1" source="worker" target="s3final">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e9" value="update cd status" edge="1" parent="1" source="worker" target="rds">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>